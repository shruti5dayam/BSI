# ============================================================
# BSI — Bank Statement Intelligence
# Example environment configuration
# ============================================================
#
# Copy this file to .env for local development:
#
#     cp .env.example .env
#
# Never place real production secrets in this example file.
# The actual .env file is ignored by Git.
# ============================================================


# ------------------------------------------------------------
# Application
# ------------------------------------------------------------

# Runtime environment: local, test, staging, or production
BSI_ENVIRONMENT=local

# Enables additional development diagnostics.
# Keep this false in staging and production.
BSI_DEBUG=false

# Application logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
BSI_LOG_LEVEL=INFO


# ------------------------------------------------------------
# FastAPI
# ------------------------------------------------------------

# Local API network address
BSI_API_HOST=127.0.0.1

# Local API port
BSI_API_PORT=8000

# Versioned API path
BSI_API_V1_PREFIX=/api/v1

# Frontend addresses permitted to call the API.
# Complex values are represented as JSON arrays.
BSI_CORS_ORIGINS=["http://localhost:8501"]


# ------------------------------------------------------------
# PostgreSQL
# ------------------------------------------------------------

# SQLAlchemy database connection URL.
# Replace the placeholder credentials inside your local .env file.
BSI_DATABASE_URL=postgresql+psycopg://bsi_user:change_me@localhost:5432/bsi

# Prints generated SQL statements when enabled.
# Keep disabled unless actively debugging database queries.
BSI_DATABASE_ECHO=false


# ------------------------------------------------------------
# File Storage
# ------------------------------------------------------------

# Supported values initially: local
# Future values may include Azure Blob Storage.
BSI_STORAGE_BACKEND=local

# Local development storage directory.
# Uploaded files must not be stored inside Git-tracked source folders.
BSI_LOCAL_STORAGE_ROOT=./var/storage

# Maximum accepted upload size in megabytes.
BSI_MAX_UPLOAD_SIZE_MB=25

# Accepted source-document extensions.
BSI_ALLOWED_UPLOAD_EXTENSIONS=[".csv",".xlsx"]


# ------------------------------------------------------------
# AI Features
# ------------------------------------------------------------

# AI remains disabled while deterministic accounting logic
# and financial tests are being established.
BSI_AI_FEATURES_ENABLED=false

# Future AI provider name, for example: azure_openai
BSI_AI_PROVIDER=

# Leave blank in this example file.
# Store the real value only in .env or a managed secret store.
BSI_AI_API_KEY=
